# ──────────────────────────────────────────────────────────────────────────────
# EaseEmail — Environment Variables (.env.local)
# Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────────────────────

# Supabase (required for auth + database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Database (Prisma direct connection)
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Microsoft Azure (MSAL OAuth)
AZURE_CLIENT_ID=your-azure-app-client-id
AZURE_CLIENT_SECRET=your-azure-app-client-secret
AZURE_TENANT_ID=your-azure-tenant-id

# AI (Claude for reply generation)
ANTHROPIC_API_KEY=sk-ant-...

# Email sending (Resend)
RESEND_API_KEY=re_...

# ──────────────────────────────────────────────────────────────────────────────
# E2E Test Configuration (required for pnpm test:e2e)
# ──────────────────────────────────────────────────────────────────────────────

# Test user email (must exist in your Supabase auth.users)
TEST_USER_EMAIL=info@tonnerow.com

# Base URL for tests (default: http://localhost:4000)
PLAYWRIGHT_BASE_URL=http://localhost:4000
