generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Tenant (Law Firm) ───────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("organizations")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id // matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  msAccounts       MsConnectedAccount[]
  msalCache        MsalTokenCache?
  deltaLinks       EmailDeltaLink[]
  webhookSubs      WebhookSubscription[]
  drafts           Draft[]
  emailRules       EmailRule[]
  signatures       Signature[]
  cachedFolders    CachedFolder[]
  cachedEmails     CachedEmail[]
  cachedCalEvents  CachedCalendarEvent[]
  cachedContacts   CachedContact[]

  @@map("users")
}

// ─── Microsoft Connected Accounts ────────────────────────────────────────────

model MsConnectedAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  homeAccountId String
  msEmail       String
  displayName   String?
  tenantId      String?
  isDefault     Boolean  @default(false)
  connectedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, homeAccountId])
  @@map("ms_connected_accounts")
}

// ─── MSAL Token Cache ─────────────────────────────────────────────────────────

model MsalTokenCache {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cacheJson String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("msal_token_cache")
}

// ─── Email Delta Links ────────────────────────────────────────────────────────

model EmailDeltaLink {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String
  folderId      String
  deltaToken    String   @db.Text
  updatedAt     DateTime @updatedAt

  @@unique([userId, homeAccountId, folderId])
  @@map("email_delta_links")
}

// ─── Webhook Subscriptions ────────────────────────────────────────────────────

model WebhookSubscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId  String
  subscriptionId String   @unique
  resource       String
  expiresAt      DateTime
  clientState    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("webhook_subscriptions")
}

// ─── Drafts ───────────────────────────────────────────────────────────────────

model Draft {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String?
  graphDraftId  String?   // MS Graph message ID — set when draft synced to Outlook
  toRecipients  Json      @default("[]")
  ccRecipients  Json      @default("[]")
  bccRecipients Json      @default("[]")
  subject       String?
  bodyHtml      String?   @db.Text
  attachments   Json      @default("[]")
  scheduledAt   DateTime? // null = send immediately; set = scheduled send
  scheduledSent Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("drafts")
}

// ─── Signatures ───────────────────────────────────────────────────────────────

model Signature {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  title     String?
  company   String?
  phone     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("signatures")
}

// ─── Sync Cache ───────────────────────────────────────────────────────────────

model CachedFolder {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId  String
  displayName    String
  parentFolderId String?
  unreadCount    Int      @default(0)
  totalCount     Int      @default(0)
  wellKnownName  String?
  syncedAt       DateTime @default(now())

  @@index([userId, homeAccountId, wellKnownName])
  @@map("cached_folders")
}

model CachedEmail {
  id               String    @id
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId    String
  folderId         String
  subject          String    @default("")
  bodyPreview      String    @default("") @db.Text
  fromName         String    @default("")
  fromAddress      String    @default("")
  toRecipients     Json      @default("[]")
  receivedDateTime DateTime
  sentDateTime     DateTime?
  isRead           Boolean   @default(false)
  hasAttachments   Boolean   @default(false)
  flagStatus       String    @default("notFlagged")
  categories       Json      @default("[]")
  syncedAt         DateTime  @default(now())

  @@index([userId, homeAccountId, folderId, receivedDateTime(sort: Desc)])
  @@index([userId, homeAccountId, isRead])
  @@index([userId, homeAccountId, flagStatus])
  @@map("cached_emails")
}

model CachedCalendarEvent {
  id               String   @id
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId    String
  subject          String   @default("")
  bodyPreview      String   @default("") @db.Text
  startDateTime    DateTime
  endDateTime      DateTime
  isAllDay         Boolean  @default(false)
  location         String?
  organizerName    String?
  organizerEmail   String?
  responseStatus   String   @default("none")
  onlineMeetingUrl String?
  attendees        Json     @default("[]")
  isRecurring      Boolean  @default(false)
  syncedAt         DateTime @default(now())

  @@index([userId, startDateTime, endDateTime])
  @@map("cached_calendar_events")
}

model CachedContact {
  id            String   @id
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String
  displayName   String   @default("")
  emailAddress  String   @default("")
  phone         String   @default("")
  jobTitle      String   @default("")
  company       String   @default("")
  syncedAt      DateTime @default(now())

  @@index([userId, homeAccountId, displayName])
  @@map("cached_contacts")
}

// ─── Deploy Log ───────────────────────────────────────────────────────────────

model DeployLog {
  id           String    @id @default(cuid())
  pusher       String
  commits      Json      // string[] of commit messages
  createdAt    DateTime  @default(now())
  digestSentAt DateTime?

  @@index([digestSentAt, createdAt])
  @@map("deploy_log")
}

// ─── Email Rules ──────────────────────────────────────────────────────────────

model EmailRule {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  priority       Int
  active         Boolean  @default(true)
  conditions     Json
  actions        Json
  emailCount     Int      @default(0)
  stopProcessing Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId, priority])
  @@map("email_rules")
}
