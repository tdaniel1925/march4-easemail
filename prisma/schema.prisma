generator client {
  provider        = "prisma-client-js"
  output          = "../lib/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Tenant (Law Firm) ───────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("organizations")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id        String   @id // matches Supabase auth.users.id
  email     String   @unique
  name      String?
  avatarUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orgId String
  org   Organization @relation(fields: [orgId], references: [id])

  // Notification preferences
  notificationNewEmail          Boolean @default(true)
  notificationDailyDigest       Boolean @default(false)
  notificationAiReplies         Boolean @default(true)
  notificationCalendarReminders Boolean @default(true)
  notificationWeeklyReport      Boolean @default(false)

  // Appearance preferences
  appTheme     String @default("light") // light | dark
  fontSize     String @default("default") // default | compact | comfortable
  emailDensity String @default("comfortable") // comfortable | compact

  // Multi-account preference
  lastActiveAccountId String?

  msAccounts       MsConnectedAccount[]
  msalCache        MsalTokenCache?
  deltaLinks       EmailDeltaLink[]
  webhookSubs      WebhookSubscription[]
  drafts           Draft[]
  emailRules       EmailRule[]
  signatures       Signature[]
  cachedFolders       CachedFolder[]
  cachedEmails        CachedEmail[]
  cachedCalEvents     CachedCalendarEvent[]
  cachedContacts      CachedContact[]
  emailAttachments    EmailAttachment[]
  aiGeneratedReplies  AiGeneratedReply[]
  cachedSearchResults CachedSearchResult[]
  syncStatuses        SyncStatus[]
  notificationLogs    NotificationLog[]
  migrationStatuses   MigrationStatus[]

  @@map("users")
}

// ─── Microsoft Connected Accounts ────────────────────────────────────────────

model MsConnectedAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  homeAccountId String
  msEmail       String
  displayName   String?
  tenantId      String?
  isDefault     Boolean  @default(false)
  connectedAt   DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, homeAccountId])
  @@map("ms_connected_accounts")
}

// ─── MSAL Token Cache ─────────────────────────────────────────────────────────

model MsalTokenCache {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cacheJson String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("msal_token_cache")
}

// ─── Email Delta Links ────────────────────────────────────────────────────────

model EmailDeltaLink {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String
  folderId      String
  deltaToken    String   @db.Text
  updatedAt     DateTime @updatedAt

  @@unique([userId, homeAccountId, folderId])
  @@map("email_delta_links")
}

// ─── Webhook Subscriptions ────────────────────────────────────────────────────

model WebhookSubscription {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId  String
  subscriptionId String   @unique
  resource       String
  expiresAt      DateTime
  clientState    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("webhook_subscriptions")
}

// ─── Drafts ───────────────────────────────────────────────────────────────────

model Draft {
  id                       String    @id @default(cuid())
  userId                   String
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId            String?
  graphDraftId             String?   // MS Graph message ID — set when draft synced to Outlook
  toRecipients             Json      @default("[]")
  ccRecipients             Json      @default("[]")
  bccRecipients            Json      @default("[]")
  subject                  String?
  bodyHtml                 String?   @db.Text
  attachments              Json      @default("[]")

  // Message settings
  importance               String    @default("normal") // normal | high | low
  sensitivity              String    @default("normal") // normal | personal | private | confidential
  requestReadReceipt       Boolean   @default(false)
  requestDeliveryReceipt   Boolean   @default(false)
  categories               Json      @default("[]")

  // Reply/forward context
  draftType                String    @default("new") // new | reply | forward
  inReplyToMessageId       String?   // Original message ID for replies
  forwardedMessageId       String?   // Original message ID for forwards
  originalMessageBody      String?   @db.Text // For preserving context

  // Scheduled send
  scheduledAt              DateTime? // null = send immediately; set = scheduled send
  scheduledSent            Boolean   @default(false)
  scheduledNotificationSent Boolean  @default(false)
  lastScheduleAttemptAt    DateTime?
  scheduleAttemptCount     Int       @default(0)

  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt

  @@map("drafts")
}

// ─── Signatures ───────────────────────────────────────────────────────────────

model Signature {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  html           String   @default("") @db.Text // Rich HTML signature body
  title          String?
  company        String?
  phone          String?
  defaultNew     Boolean  @default(false) // Use for new emails
  defaultReplies Boolean  @default(false) // Use for replies/forwards
  account        String   @default("all") // Account scope: "all" or specific email
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("signatures")
}

// ─── Sync Cache ───────────────────────────────────────────────────────────────

model CachedFolder {
  id             String   @id
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId  String
  displayName    String
  parentFolderId String?
  unreadCount    Int      @default(0)
  totalCount     Int      @default(0)
  wellKnownName  String?
  syncedAt       DateTime @default(now())

  @@index([userId, homeAccountId, wellKnownName])
  @@map("cached_folders")
}

model CachedEmail {
  id                      String    @id
  userId                  String
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId           String
  folderId                String
  subject                 String    @default("")
  bodyPreview             String    @default("") @db.Text
  fromName                String    @default("")
  fromAddress             String    @default("")
  toRecipients            Json      @default("[]")
  receivedDateTime        DateTime
  sentDateTime            DateTime?
  isRead                  Boolean   @default(false)
  hasAttachments          Boolean   @default(false)
  flagStatus              String    @default("notFlagged")
  categories              Json      @default("[]")

  // Additional metadata
  importance              String    @default("normal") // normal | high | low
  sensitivity             String    @default("normal") // normal | personal | private | confidential
  inferenceClassification String    @default("other") // focused | other
  conversationId          String?
  isDraft                 Boolean   @default(false)
  syncStatus              String    @default("synced")
  lastModifiedDateTime    DateTime?

  syncedAt                DateTime  @default(now())

  @@index([userId, homeAccountId, folderId, receivedDateTime(sort: Desc)])
  @@index([userId, homeAccountId, isRead])
  @@index([userId, homeAccountId, flagStatus])
  @@map("cached_emails")
}

model CachedCalendarEvent {
  id                   String    @id
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId        String
  subject              String    @default("")
  bodyPreview          String    @default("") @db.Text
  bodyHtml             String?   @db.Text
  startDateTime        DateTime
  endDateTime          DateTime
  isAllDay             Boolean   @default(false)
  location             String?
  organizerName        String?
  organizerEmail       String?
  organizerType        String    @default("required") // required | optional
  responseStatus       String    @default("none")
  onlineMeetingUrl     String?
  attendees            Json      @default("[]")
  isRecurring          Boolean   @default(false)

  // Event settings
  reminderMinutes      Int?      // Reminder time in minutes (null = no reminder)
  showAs               String    @default("busy") // busy | free | tentative
  recurrence           String?   // daily | weekly | monthly | null
  eventColor           String?
  timeZone             String    @default("UTC")

  // Teams meeting data
  teamsMeetingUrl      String?
  teamsMeetingId       String?

  // Recurrence tracking
  seriesMasterId       String?
  iCalUId              String?
  calendarId           String?

  // Timestamps
  createdDateTime      DateTime?
  lastModifiedDateTime DateTime?
  syncedAt             DateTime  @default(now())

  @@index([userId, startDateTime, endDateTime])
  @@map("cached_calendar_events")
}

model CachedContact {
  id              String    @id
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId   String
  displayName     String    @default("")
  emailAddress    String    @default("") // Legacy - use emailAddresses array
  phone           String    @default("") // Legacy - use phones array
  jobTitle        String    @default("")
  company         String    @default("")
  department      String    @default("")

  // Structured contact data
  emailAddresses  Json      @default("[]") // Array of {address, name}
  phones          Json      @default("[]") // Array of {type, value}
  givenName       String    @default("")
  surname         String    @default("")
  middleName      String    @default("")
  addresses       Json      @default("[]") // Structured addresses
  imAddresses     Json      @default("[]") // IM handles

  // CRM features
  categories      Json      @default("[]") // Tags/labels
  notes           String    @default("")
  birthday        DateTime?
  anniversary     DateTime?
  manager         String?
  directReports   Json      @default("[]")
  frequencyScore  Int       @default(0)
  isVIP           Boolean   @default(false)
  isFavorite      Boolean   @default(false)

  syncedAt        DateTime  @default(now())

  @@index([userId, homeAccountId, displayName])
  @@map("cached_contacts")
}

// ─── Deploy Log ───────────────────────────────────────────────────────────────

model DeployLog {
  id           String    @id @default(cuid())
  pusher       String
  commits      Json      // string[] of commit messages
  createdAt    DateTime  @default(now())
  digestSentAt DateTime?

  @@index([digestSentAt, createdAt])
  @@map("deploy_log")
}

// ─── Email Rules ──────────────────────────────────────────────────────────────

model EmailRule {
  id                  String    @id @default(cuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                String
  priority            Int
  active              Boolean   @default(true)
  conditions          Json
  actions             Json
  emailCount          Int       @default(0)
  stopProcessing      Boolean   @default(false)

  // Execution tracking
  lastExecutedAt      DateTime?
  lastExecutionStatus String?
  lastExecutionError  String?
  failureCount        Int       @default(0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([userId, priority])
  @@map("email_rules")
}

// ─── Email Attachments ────────────────────────────────────────────────────────

model EmailAttachment {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId       String
  graphMessageId  String?
  fileName        String
  contentType     String
  size            Int
  contentHash     String?
  isInline        Boolean  @default(false)
  contentId       String?
  uploadedAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  @@index([userId, messageId])
  @@index([graphMessageId])
  @@map("email_attachments")
}

// ─── AI Generated Replies ─────────────────────────────────────────────────────

model AiGeneratedReply {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messageId     String
  generatedBody String   @db.Text
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@index([userId, messageId])
  @@index([expiresAt])
  @@map("ai_generated_replies")
}

// ─── Search Cache ─────────────────────────────────────────────────────────────

model CachedSearchResult {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String
  query         String
  results       Json
  createdAt     DateTime @default(now())
  expiresAt     DateTime

  @@unique([userId, homeAccountId, query])
  @@index([expiresAt])
  @@map("cached_search_results")
}

// ─── Sync Status ──────────────────────────────────────────────────────────────

model SyncStatus {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  homeAccountId String
  resourceType  String
  lastSyncedAt  DateTime @default(now())
  status        String   @default("success")
  errorMessage  String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([userId, homeAccountId, resourceType])
  @@index([lastSyncedAt])
  @@map("sync_status")
}

// ─── Notification Log ─────────────────────────────────────────────────────────

model NotificationLog {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type         String
  sentAt       DateTime @default(now())
  status       String
  errorMessage String?
  metadata     Json     @default("{}")

  @@index([userId, type])
  @@index([sentAt])
  @@map("notification_log")
}

// ─── Migration Status ─────────────────────────────────────────────────────────

model MigrationStatus {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  migrationType String
  completedAt   DateTime @default(now())
  metadata      Json     @default("{}")

  @@unique([userId, migrationType])
  @@map("migration_status")
}
